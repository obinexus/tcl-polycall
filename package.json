{
  "name": "@obinexusltd/tcl-polycall",
  "version": "1.0.0",
  "description": "Tcl 9 source binding for libpolycall 1.5",
  "main": "index.js",
  "type": "commonjs",
  "exports": {
    ".": "./index.js",
    "./package.json": "./package.json",
    "./src/*": "./src/*",
    "./include/*": "./include/*",
    "./generated/*": "./generated/*",
    "./dist/*": "./dist/*",
    "./examples/*": "./examples/*",
    "./tests/*": "./tests/*",
    "./scripts/*": "./scripts/*"
  },
  "files": [
    "index.js",
    "pkgIndex.tcl",
    "src/",
    "include/",
    "generated/",
    "dist/",
    "examples/",
    "tests/",
    "scripts/",
    "Makefile",
    "tcl-polycallrc",
    "polycall-binding.json",
    "README.md",
    "TODO.md",
    "LICENSE"
  ],
  "directories": {
    "lib": "src",
    "src": "src",
    "include": "include",
    "generated": "generated",
    "dist": "dist",
    "example": "examples",
    "test": "tests",
    "scripts": "scripts"
  },
  "scripts": {
    "build": "make",
    "build:tcl": "make extension",
    "check:tcl": "make tcl-check",
    "test": "make test && make tcl-check-if-available && npm run verify:dry && npm run test:package",
    "test:tcl": "make test-tcl",
    "test:package": "node tests/package.test.js",
    "verify:dry": "make verify-dry",
    "verify": "npm test",
    "prepack": "npm test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/obinexus/tcl-polycall.git"
  },
  "keywords": [
    "libpolycall",
    "polycall",
    "tcl",
    "tcl9",
    "ffi"
  ],
  "author": "Nnamdi Michael Okpala <okpalan@protonmail.com>",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "bugs": {
    "url": "https://github.com/obinexus/tcl-polycall/issues"
  },
  "homepage": "https://github.com/obinexus/tcl-polycall#readme"
}
