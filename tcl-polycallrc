# tcl-polycallrc - read-only Tcl runtime overrides for libpolycall
#
# This file uses the SHARED polycall schema (src/config/polycall_config_schema.c).
# It introduces no new keys or parser: the Tcl adapter passes this path to
# the core via the FFI boundary. Values here override polycallrc for Tcl.

log_level=info
max_connections=1000
network_timeout=5000
tls_enabled=false
